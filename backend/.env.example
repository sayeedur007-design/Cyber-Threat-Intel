# --- Security ---
# Change this to a long random string in production
JWT_SECRET_KEY=super-secret-key-change-this-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# For local SQLite, leave empty or use: sqlite:///./database/sqlite/cti_app.db
# For production (Render/Postgres), use: postgresql://user:password@host:port/dbname
DATABASE_URL=

# --- RAG & AI ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=800
TOP_K=5

# --- Optional ---
# SQLITE_DB_PATH=./database/sqlite/cti_app.db

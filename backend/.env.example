# ==============================================================================
#                 CTI ANALYST PLATFORM - PRODUCTION ENV EXAMPLE
# ==============================================================================

# ------------------------------------------------------------------------------
# --- Security & JWT Settings ---
# ------------------------------------------------------------------------------
# SECRET: Generate a secure 32-byte or 64-byte hex string in production:
# Command to generate: openssl rand -hex 32
JWT_SECRET_KEY=super-secret-key-change-this-for-production-deployment-v1
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# --- API & Network Settings ---
# ------------------------------------------------------------------------------
# PORT: E.g., 8000 for local. Railway/Render will automatically inject their own $PORT.
PORT=8000
BACKEND_API_URL=http://localhost:8000

# CORS_ORIGINS: Comma-separated list of allowed origins.
# For local dev, include localhost origins. For production, add your Vercel domains.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://cti-analyst-platform.vercel.app

# ------------------------------------------------------------------------------
# --- Database Configuration ---
# ------------------------------------------------------------------------------
# --- CASE A: Local Development (SQLite Fallback) ---
# To use the automatic SQLite fallback, leave DATABASE_URL blank or comment it out.
# Relative paths will automatically resolve to absolute paths under the backend root.
# DATABASE_URL=

# --- CASE B: Production Deployment (PostgreSQL) ---
# Inject your hosting provider's (e.g. Railway) PostgreSQL connection string.
# NOTE: Both 'postgres://' and 'postgresql://' prefixes are automatically supported.
DATABASE_URL=postgresql://postgres:password@localhost:5432/cti_db

# --- Optional SQLite Specific Override ---
# SQLITE_DB_PATH=cti_database.db

# ------------------------------------------------------------------------------
# --- AI & RAG Configuration ---
# ------------------------------------------------------------------------------
# OLLAMA_BASE_URL: E.g., http://localhost:11434 for local, or Docker/DNS address
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# EMBEDDING_MODEL: The HuggingFace sentence transformer used for RAG embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CHUNK_SIZE & RETRIEVAL: Control document splitting parameters
CHUNK_SIZE=800
TOP_K=5

# ------------------------------------------------------------------------------
# --- Risk Scoring Engine Parameters ---
# ------------------------------------------------------------------------------
# Keywords lists: Comma-separated lowercased words
RISK_KEYWORDS_CRITICAL=remote code execution,rce,zero-day,exploit,unauthenticated
RISK_KEYWORDS_HIGH=privilege escalation,authentication bypass,lateral movement,ransomware,injection
RISK_KEYWORDS_MEDIUM=denial of service,dos,phishing,information disclosure

# Weights: Modulation factors for calculating CTI risk scores (0-100)
RISK_WEIGHT_CVSS=5.0
RISK_WEIGHT_CRITICAL=35
RISK_WEIGHT_HIGH=20
RISK_WEIGHT_MEDIUM=10
